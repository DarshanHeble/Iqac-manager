# IQAC Worklog Application - Environment Variables
# Copy this file to .env and fill in your actual values

# PostgreSQL Database URL (REQUIRED)
# Format: postgresql://username:password@host:port/database
# For Render: This is automatically provided as DATABASE_URL
# For local development, you can use a local PostgreSQL or cloud service like ElephantSQL, Supabase, Neon, etc.
DATABASE_URL=postgresql://username:123456@localhost:5432/iqac_worklog

# NVIDIA API Configuration
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL_NAME=meta/llama-3.1-8b-instruct


# Application Secret Key (REQUIRED for production)
# Generate a secure random string for production
SECRET_KEY=your_secret_key_here

# SMTP Email Settings (Optional - for sending emails)
# Gmail SMTP Configuration
SMTP_EMAIL=associatedirector.iqac@christuniversity.in
SMTP_PASSWORD=sbjeumibabhrvyhs

# Note: For Gmail, you need to:
# 1. Enable 2-Factor Authentication on your Google account
# 2. Generate an App Password at https://myaccount.google.com/apppasswords
# 3. Use the generated App Password as SMTP_PASSWORD
BREVO_API_KEY=xxx
SENDER_EMAIL=xxx

# Google Drive Integration Settings (Optional)
# If GOOGLE_DRIVE_FOLDER_ID is set, files will be saved in Google Drive instead of Cloudinary.
# Require a Service Account credential JSON file placed in the project root as `service_account.json` or path in GOOGLE_SERVICE_ACCOUNT_JSON.
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here
GOOGLE_SERVICE_ACCOUNT_JSON=service_account.json